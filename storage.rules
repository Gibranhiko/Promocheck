rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function isOperator() {
      return isAuthenticated() &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == "operator";
    }

    function isValidPhoto() {
      return request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    function isVisitOwner(visitId) {
      return firestore.get(/databases/(default)/documents/visits/$(visitId)).data.promoterId == request.auth.uid;
    }

    // Path: visits/{visitId}/{fileName}
    // fileName format: {category}_{sequence}_{timestamp}.jpg
    match /visits/{visitId}/{fileName} {
      allow read: if isAdmin() || (isOperator() && isVisitOwner(visitId));
      allow write: if isOperator() && isValidPhoto() && isVisitOwner(visitId);
      allow delete: if false;
    }
  }
}
