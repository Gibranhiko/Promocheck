rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Data Model
    // ===============================================================
    //
    // Collection: visits
    // Document ID: local id set by client (idempotent sync)
    // Fields:
    //   - id: string (required)
    //   - localId: string (required)
    //   - visitType: string (required) - "routine" | "audit" | "special_event"
    //   - visitDate: int (required) - unix ms del día de visita
    //   - promoterId: string (required, immutable) - must match auth uid on create
    //   - promoterName: string (required, 1-100 chars)
    //   - storeId: string (required, immutable)
    //   - storeName: string (required, 1-100 chars)
    //   - photos: map (required, can be empty)
    //   - status: string (required) - "pending_sync"|"synced"|"approved"|"rejected"|"error"
    //   - notes: string (optional, max 500 chars)
    //   - overallCondition: string (optional) - "good" | "regular" | "bad"
    //   - rejectionReason: string (optional)
    //   - createdAt: int (required, immutable) - unix ms timestamp
    //   - syncedAt: int (optional)
    //   - errorMessage: string (optional)
    //
    // Collection: stores
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required, 1-100 chars)
    //   - storeType: string (required) - "supermarket"|"convenience"|"pharmacy"|"other"
    //   - visitFrequency: string (required) - "weekly"|"biweekly"|"monthly"
    //   - address: string (optional)
    //   - chain: string (optional)
    //   - contactName: string (optional)
    //   - contactPhone: string (optional)
    //   - active: bool (required)
    //   - createdAt: int (required, immutable)
    //   - createdBy: string (required, immutable)
    //
    // Collection: users / audit_log — sin cambios
    //
    // Collection: config
    //   - /config/photo_requirements: { required: list<string> }
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function isOperator() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "operator";
    }

    function isOwnDoc(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidVisit() {
      let data = request.resource.data;
      return data.keys().hasAll([
          'visitType', 'visitDate', 'promoterId', 'promoterName',
          'storeId', 'storeName', 'photos', 'status', 'createdAt'
        ])
        && data.visitType in ['routine', 'audit', 'special_event']
        && data.visitDate is int
        && data.promoterId is string
        && data.promoterId == request.auth.uid
        && data.promoterName is string
        && data.promoterName.size() >= 1
        && data.promoterName.size() <= 100
        && data.storeId is string
        && data.storeId.size() >= 1
        && data.storeName is string
        && data.storeName.size() >= 1
        && data.storeName.size() <= 100
        && data.photos is map
        && data.status in ['pending_sync', 'synced', 'approved', 'rejected', 'error']
        && data.createdAt is int;
    }

    function isValidVisitUpdate() {
      let data = request.resource.data;
      return data.promoterId == resource.data.promoterId
        && data.createdAt == resource.data.createdAt
        && data.status in ['pending_sync', 'synced', 'approved', 'rejected', 'error']
        && data.photos is map;
    }

    function isValidStore() {
      let data = request.resource.data;
      return data.keys().hasAll(['name', 'storeType', 'visitFrequency', 'active', 'createdAt', 'createdBy'])
        && data.name is string
        && data.name.size() >= 1
        && data.name.size() <= 100
        && data.storeType in ['supermarket', 'convenience', 'pharmacy', 'other']
        && data.visitFrequency in ['weekly', 'biweekly', 'monthly']
        && data.active is bool
        && data.createdAt is int
        && data.createdBy is string;
    }

    function isValidStoreUpdate() {
      let data = request.resource.data;
      return data.createdAt == resource.data.createdAt
        && data.createdBy == resource.data.createdBy
        && data.name is string
        && data.name.size() >= 1
        && data.name.size() <= 100
        && data.storeType in ['supermarket', 'convenience', 'pharmacy', 'other']
        && data.visitFrequency in ['weekly', 'biweekly', 'monthly']
        && data.active is bool;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /visits/{visitId} {
      allow read: if isAdmin() || isOperator();

      allow create: if isOperator() && isValidVisit();

      allow update: if isAdmin() ||
        (isOperator()
          && resource.data.promoterId == request.auth.uid
          && isValidVisitUpdate());

      allow delete: if false;
    }

    match /stores/{storeId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidStore();
      allow update: if isAdmin() && isValidStoreUpdate();
      allow delete: if isAdmin();
    }

    match /audit_log/{entryId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    match /users/{userId} {
      allow read: if isOwnDoc(userId) || isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin() ||
        (isOwnDoc(userId) &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(["role"]));
      allow delete: if false;
    }

    match /config/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
