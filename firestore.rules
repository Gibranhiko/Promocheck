rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Data Model
    // ===============================================================
    //
    // Collection: visits
    // Collection: stores
    // Collection: products
    // Collection: store_products
    // Collection: stock_snapshots
    // Collection: routes
    // Collection: route_stores
    // Collection: visit_plans
    // Collection: users
    // Collection: config  — /config/photo_requirements, /config/alert_settings
    // Collection: audit_log
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function isOperator() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "operator";
    }

    function isOwnDoc(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidVisit() {
      let data = request.resource.data;
      return data.keys().hasAll([
          'visitType', 'visitDate', 'promoterId', 'promoterName',
          'storeId', 'storeName', 'photos', 'status', 'createdAt'
        ])
        && data.visitType in ['routine', 'audit', 'special_event']
        && data.visitDate is int
        && data.promoterId is string
        && data.promoterId == request.auth.uid
        && data.promoterName is string
        && data.promoterName.size() >= 1
        && data.promoterName.size() <= 100
        && data.storeId is string
        && data.storeId.size() >= 1
        && data.storeName is string
        && data.storeName.size() >= 1
        && data.storeName.size() <= 100
        && data.photos is map
        && data.status in ['pending_sync', 'synced', 'approved', 'rejected', 'error']
        && data.createdAt is int;
    }

    function isValidVisitUpdate() {
      let data = request.resource.data;
      return data.promoterId == resource.data.promoterId
        && data.createdAt == resource.data.createdAt
        && data.status in ['pending_sync', 'synced', 'approved', 'rejected', 'error']
        && data.photos is map;
    }

    function isValidStore() {
      let data = request.resource.data;
      return data.keys().hasAll(['name', 'storeType', 'visitFrequency', 'active', 'createdAt', 'createdBy'])
        && data.name is string
        && data.name.size() >= 1
        && data.name.size() <= 100
        && data.storeType in ['supermarket', 'convenience', 'pharmacy', 'other']
        && data.visitFrequency in ['weekly', 'biweekly', 'monthly']
        && data.active is bool
        && data.createdAt is int
        && data.createdBy is string;
    }

    function isValidSnapshot() {
      let data = request.resource.data;
      return data.keys().hasAll([
          'visitId', 'storeId', 'productId',
          'shelfQty', 'backroomQty', 'totalQty',
          'needsReorder', 'capturedAt', 'capturedById', 'status'
        ])
        && data.capturedById == request.auth.uid
        && data.shelfQty is int && data.shelfQty >= 0
        && data.backroomQty is int && data.backroomQty >= 0
        && data.totalQty is int && data.totalQty >= 0
        && data.needsReorder is bool
        && data.status in ['pending_sync', 'synced'];
    }

    function isValidVisitPlanUpdate() {
      let data = request.resource.data;
      return data.promoterId == resource.data.promoterId
        && data.routeId == resource.data.routeId
        && data.storeId == resource.data.storeId
        && data.plannedDate == resource.data.plannedDate
        && data.createdAt == resource.data.createdAt
        && data.status in ['pending', 'completed', 'missed'];
    }

    function isValidStoreUpdate() {
      let data = request.resource.data;
      return data.createdAt == resource.data.createdAt
        && data.createdBy == resource.data.createdBy
        && data.name is string
        && data.name.size() >= 1
        && data.name.size() <= 100
        && data.storeType in ['supermarket', 'convenience', 'pharmacy', 'other']
        && data.visitFrequency in ['weekly', 'biweekly', 'monthly']
        && data.active is bool;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    // Visits: promotoras ven solo sus propias visitas; admin ve todas
    match /visits/{visitId} {
      allow read: if isAdmin() ||
        (isOperator() && resource.data.promoterId == request.auth.uid);

      allow create: if isOperator() && isValidVisit();

      allow update: if isAdmin() ||
        (isOperator()
          && resource.data.promoterId == request.auth.uid
          && isValidVisitUpdate());

      allow delete: if false;
    }

    // Stores: todos los autenticados pueden leer (necesario para el form de visita)
    match /stores/{storeId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidStore();
      allow update: if isAdmin() && isValidStoreUpdate();
      allow delete: if isAdmin();
    }

    // Audit log: solo admin
    match /audit_log/{entryId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    // Users: cada quien lee su propio doc; admin lee todos
    // isAdmin() aquí lee users/{auth.uid} (el doc del llamante), no users/{userId} — no hay circular dependency
    match /users/{userId} {
      allow read: if isOwnDoc(userId) || isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin() ||
        (isOwnDoc(userId) &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(["role"]));
      allow delete: if false;
    }

    // Config: lectura para todos los autenticados, escritura solo admin
    match /config/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Products: catálogo de productos — lectura para todos (promotoras necesitan la lista al contar)
    match /products/{productId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if false;
    }

    // Store Products: asignaciones tienda-producto y umbrales
    match /store_products/{spId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if false;
    }

    // Stock Snapshots: escritura por la promotora que captura (capturedById == uid)
    match /stock_snapshots/{snapId} {
      allow read: if isAdmin() ||
        (isOperator() && resource.data.capturedById == request.auth.uid);

      // setDoc desde el sync engine — la promotora crea/sobreescribe su propio snapshot
      allow create: if isOperator() && isValidSnapshot();
      allow update: if isAdmin() ||
        (isOperator() && resource.data.capturedById == request.auth.uid);
      allow delete: if false;
    }

    // Routes: admin gestiona; promotora ve solo sus rutas
    match /routes/{routeId} {
      allow read: if isAdmin() ||
        (isOperator() && resource.data.promoterId == request.auth.uid);
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if false;
    }

    // Route Stores: configuración de tiendas por ruta — lectura autenticada
    match /route_stores/{rsId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if false;
    }

    // Visit Plans: admin genera; promotora ve y actualiza solo los suyos
    match /visit_plans/{planId} {
      allow read: if isAdmin() ||
        (isOperator() && resource.data.promoterId == request.auth.uid);

      allow create: if isAdmin();

      // Promotora puede marcar completed/missed en sus propios planes
      allow update: if isAdmin() ||
        (isOperator()
          && resource.data.promoterId == request.auth.uid
          && isValidVisitPlanUpdate());

      allow delete: if false;
    }
  }
}
